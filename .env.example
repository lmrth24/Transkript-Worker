SUPADATA_API_KEY=dein_supadata_api_key_hier_einfuegen

# Optional: Wenn gesetzt, setzt der Worker nach dem Einfügen des Transkripts
# eine Status-Property der Notion-Seite auf diesen Wert.
# Beispiele: "Transkript da", "Bereit zur Auswertung", "Done"
# Leer lassen oder Zeile entfernen, um das Status-Update zu deaktivieren.
# Voraussetzung: Deine Datenbank hat eine Property namens "Status" (Typ: Status)
# mit einer Option, die exakt so heißt wie hier eingetragen.
STATUS_AFTER_TRANSCRIPT=
